{
  "manifest_version": 3,
  "name": "SubBatch - B站字幕批量下载工具",
  "version": "2.0.0",
  "description": "一键批量下载B站(Bilibili)视频字幕，支持导出SRT/TXT/MD/DOC格式。支持批量处理个人主页、收藏夹、合集、视频选集、单个视频的字幕，本地处理，安全高效。",
  "icons": {
    "16": "images/logo/logo-16.png",
    "32": "images/logo/logo-32.png",
    "48": "images/logo/logo-48.png",
    "128": "images/logo/logo-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/logo/logo-16.png",
      "32": "images/logo/logo-32.png",
      "48": "images/logo/logo-48.png",
      "128": "images/logo/logo-128.png"
    }
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "cookies",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://www.bilibili.com/*",
    "https://i0.hdslb.com/*",
    "https://i1.hdslb.com/*",
    "https://i2.hdslb.com/*",
    "https://aisubtitle.hdslb.com/*",
    "https://upos-sz-mirrorhw.bilivideo.com/*",
    "https://*.bilivideo.com/*",
    "https://cors-anywhere.herokuapp.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://*.bilibili.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "models/*",
        "libs/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
